        "def determine_seriousness_v4(row):\n",
        "    score = 0\n",
        "    stats = orientation_stats[row['sexual_orientation']]\n",
        "\n",
        "    # --- EXISTING 4 EFFORT RULES ---\n",
        "    if (stats['bio_length'] - 100) <= row['bio_length'] <= (stats['bio_length'] + 100): score += 1\n",
        "    if row['swipe_right_ratio'] < stats['swipe_right_ratio']: score += 1\n",
        "    if row['message_sent_count'] > stats['message_sent_count']: score += 1\n",
        "    if (stats['emoji_usage_rate'] - 0.15) <= row['emoji_usage_rate'] <= (stats['emoji_usage_rate'] + 0.15): score += 1\n",
        "\n",
        "    # --- NEW FORMULA 1: Conversation Density ---\n",
        "    # We reward users who spend their time actually talking (Above 0.5 msg/min)\n",
        "    if row['app_usage_time_min'] > 0:\n",
        "        msg_density = row['message_sent_count'] / row['app_usage_time_min']\n",
        "        if msg_density > 0.5: score += 1\n",
        "\n",
        "    # --- NEW FORMULA 2: Match ROI ---\n",
        "    # Selective swiping that actually leads to matches\n",
        "    if row['swipe_right_ratio'] > 0:\n",
        "        match_roi = row['mutual_matches'] / row['swipe_right_ratio']\n",
        "        if match_roi > 5: score += 1 # Rewards high match yield per swipe\n",
        "\n",
        "    # --- THE RED FLAG PENALTY (Your custom logic) ---\n",
        "    red_flag_outcomes = ['Relationship Formed', 'No Action', 'Blocked']\n",
        "    if row['match_outcome'] in red_flag_outcomes:\n",
        "        score -= 1\n",
        "\n",
        "    # --- FINAL CLASSIFICATION ---\n",
        "    # 4 out of 7 is the passing grade for \"Serious\"\n",
        "    return 1 if score >= 4 else 0\n",
        "\n",
        "# Apply to your data\n",
        "df_9['is_serious'] = df_9.apply(determine_seriousness_v4, axis=1)\n",
        "\n",
        "print(f\"✅ Final Logic Applied! Serious Users: {df_9['is_serious'].sum()}\")"
